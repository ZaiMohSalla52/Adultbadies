# Public Supabase runtime variables (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional service role key for privileged server-side jobs (never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (text + image generation)
OPENAI_API_KEY=your-openai-api-key

# Cloudflare R2 (source-of-truth originals)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name

# Cloudinary (delivery + responsive transformations)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=adultbadiesvirtual-girlfriend

# Ideogram (image provider migration scaffolding)
IDEOGRAM_API_KEY=your-ideogram-api-key
IDEOGRAM_BASE_URL=https://api.ideogram.ai
IDEOGRAM_MODEL=V_3
